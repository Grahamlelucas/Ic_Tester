{
  "chipId": "7490",
  "name": "Decade Counter",
  "manufacturer": "Texas Instruments",
  "package": "14-pin DIP",
  "description": "Decade counter with divide-by-2 and divide-by-5 sections. Counts from 0000 to 1001 (0-9 decimal) then resets.",
  
  "pinout": {
    "vcc": 5,
    "gnd": 10,
    "inputs": [
      {"pin": 14, "name": "CKA", "description": "Clock Input A"},
      {"pin": 1, "name": "CKB", "description": "Clock Input B"},
      {"pin": 2, "name": "R0_1", "description": "Reset to 0 input 1"},
      {"pin": 3, "name": "R0_2", "description": "Reset to 0 input 2"},
      {"pin": 6, "name": "R9_1", "description": "Reset to 9 input 1"},
      {"pin": 7, "name": "R9_2", "description": "Reset to 9 input 2"}
    ],
    "outputs": [
      {"pin": 12, "name": "QA", "description": "Output A (LSB, 2^0)"},
      {"pin": 9, "name": "QB", "description": "Output B (2^1)"},
      {"pin": 8, "name": "QC", "description": "Output C (2^2)"},
      {"pin": 11, "name": "QD", "description": "Output D (MSB, 2^3)"}
    ],
    "noConnect": [4, 13]
  },
  
  "arduinoMapping": {
    "comment": "Maps chip pins to Arduino pins for testing",
    "power": {
      "5": "5V",
      "10": "GND"
    },
    "io": {
      "1": 2,
      "2": 3,
      "3": 4,
      "6": 5,
      "7": 6,
      "8": 7,
      "9": 8,
      "11": 9,
      "12": 10,
      "14": 11
    }
  },
  
  "testSequence": {
    "description": "Test sequence for 7490 decade counter",
    "setup": [
      {
        "step": 1,
        "action": "Initialize all inputs LOW",
        "pins": {"CKA": "LOW", "CKB": "LOW", "R0_1": "LOW", "R0_2": "LOW", "R9_1": "LOW", "R9_2": "LOW"}
      }
    ],
    "tests": [
      {
        "testId": 1,
        "description": "Reset to 0 (both R0 inputs HIGH)",
        "inputs": {"R0_1": "HIGH", "R0_2": "HIGH", "R9_1": "LOW", "R9_2": "LOW", "CKA": "LOW", "CKB": "LOW"},
        "expectedOutputs": {"QA": "LOW", "QB": "LOW", "QC": "LOW", "QD": "LOW"},
        "binaryValue": "0000",
        "decimalValue": 0
      },
      {
        "testId": 2,
        "description": "Reset to 9 (both R9 inputs HIGH)",
        "inputs": {"R0_1": "LOW", "R0_2": "LOW", "R9_1": "HIGH", "R9_2": "HIGH", "CKA": "LOW", "CKB": "LOW"},
        "expectedOutputs": {"QA": "HIGH", "QB": "LOW", "QC": "LOW", "QD": "HIGH"},
        "binaryValue": "1001",
        "decimalValue": 9
      },
      {
        "testId": 3,
        "description": "Reset back to 0 before counting",
        "inputs": {"R0_1": "HIGH", "R0_2": "HIGH", "R9_1": "LOW", "R9_2": "LOW", "CKA": "LOW", "CKB": "LOW"},
        "expectedOutputs": {"QA": "LOW", "QB": "LOW", "QC": "LOW", "QD": "LOW"},
        "binaryValue": "0000",
        "decimalValue": 0
      },
      {
        "testId": 4,
        "description": "Count 1 — pulse CKA (QA goes HIGH, CKB not clocked yet)",
        "inputs": {"R0_1": "LOW", "R0_2": "LOW", "R9_1": "LOW", "R9_2": "LOW", "CKA": "LOW", "CKB": "LOW"},
        "clock": ["CKA"],
        "expectedOutputs": {"QA": "HIGH", "QB": "LOW", "QC": "LOW", "QD": "LOW"},
        "binaryValue": "0001",
        "decimalValue": 1
      },
      {
        "testId": 5,
        "description": "Count 2 — pulse CKA (QA LOW→HIGH→LOW triggers CKB via software)",
        "inputs": {"R0_1": "LOW", "R0_2": "LOW", "R9_1": "LOW", "R9_2": "LOW", "CKA": "LOW", "CKB": "LOW"},
        "clock": ["CKA", "CKB"],
        "expectedOutputs": {"QA": "LOW", "QB": "HIGH", "QC": "LOW", "QD": "LOW"},
        "binaryValue": "0010",
        "decimalValue": 2
      },
      {
        "testId": 6,
        "description": "Count 3 — pulse CKA only (QA goes HIGH again, QB stays HIGH)",
        "inputs": {"R0_1": "LOW", "R0_2": "LOW", "R9_1": "LOW", "R9_2": "LOW", "CKA": "LOW", "CKB": "LOW"},
        "clock": ["CKA"],
        "expectedOutputs": {"QA": "HIGH", "QB": "HIGH", "QC": "LOW", "QD": "LOW"},
        "binaryValue": "0011",
        "decimalValue": 3
      },
      {
        "testId": 7,
        "description": "Count 4 — pulse CKA then CKB (QA falls, triggers QB→QC ripple)",
        "inputs": {"R0_1": "LOW", "R0_2": "LOW", "R9_1": "LOW", "R9_2": "LOW", "CKA": "LOW", "CKB": "LOW"},
        "clock": ["CKA", "CKB"],
        "expectedOutputs": {"QA": "LOW", "QB": "LOW", "QC": "HIGH", "QD": "LOW"},
        "binaryValue": "0100",
        "decimalValue": 4
      },
      {
        "testId": 8,
        "description": "Count 5 — pulse CKA only (QA HIGH, QC HIGH)",
        "inputs": {"R0_1": "LOW", "R0_2": "LOW", "R9_1": "LOW", "R9_2": "LOW", "CKA": "LOW", "CKB": "LOW"},
        "clock": ["CKA"],
        "expectedOutputs": {"QA": "HIGH", "QB": "LOW", "QC": "HIGH", "QD": "LOW"},
        "binaryValue": "0101",
        "decimalValue": 5
      },
      {
        "testId": 9,
        "description": "Count 6 — pulse CKA then CKB (QA falls, QC and QB HIGH)",
        "inputs": {"R0_1": "LOW", "R0_2": "LOW", "R9_1": "LOW", "R9_2": "LOW", "CKA": "LOW", "CKB": "LOW"},
        "clock": ["CKA", "CKB"],
        "expectedOutputs": {"QA": "LOW", "QB": "HIGH", "QC": "HIGH", "QD": "LOW"},
        "binaryValue": "0110",
        "decimalValue": 6
      },
      {
        "testId": 10,
        "description": "Count 7 — pulse CKA only (QA HIGH, QB HIGH, QC HIGH)",
        "inputs": {"R0_1": "LOW", "R0_2": "LOW", "R9_1": "LOW", "R9_2": "LOW", "CKA": "LOW", "CKB": "LOW"},
        "clock": ["CKA"],
        "expectedOutputs": {"QA": "HIGH", "QB": "HIGH", "QC": "HIGH", "QD": "LOW"},
        "binaryValue": "0111",
        "decimalValue": 7
      },
      {
        "testId": 11,
        "description": "Count 8 — pulse CKA then CKB (all lower bits reset, QD HIGH)",
        "inputs": {"R0_1": "LOW", "R0_2": "LOW", "R9_1": "LOW", "R9_2": "LOW", "CKA": "LOW", "CKB": "LOW"},
        "clock": ["CKA", "CKB"],
        "expectedOutputs": {"QA": "LOW", "QB": "LOW", "QC": "LOW", "QD": "HIGH"},
        "binaryValue": "1000",
        "decimalValue": 8
      },
      {
        "testId": 12,
        "description": "Count 9 — pulse CKA only (QA HIGH, QD HIGH = 1001)",
        "inputs": {"R0_1": "LOW", "R0_2": "LOW", "R9_1": "LOW", "R9_2": "LOW", "CKA": "LOW", "CKB": "LOW"},
        "clock": ["CKA"],
        "expectedOutputs": {"QA": "HIGH", "QB": "LOW", "QC": "LOW", "QD": "HIGH"},
        "binaryValue": "1001",
        "decimalValue": 9
      },
      {
        "testId": 13,
        "description": "Count wraps to 0 — pulse CKA then CKB (counter rolls over from 9 to 0)",
        "inputs": {"R0_1": "LOW", "R0_2": "LOW", "R9_1": "LOW", "R9_2": "LOW", "CKA": "LOW", "CKB": "LOW"},
        "clock": ["CKA", "CKB"],
        "expectedOutputs": {"QA": "LOW", "QB": "LOW", "QC": "LOW", "QD": "LOW"},
        "binaryValue": "0000",
        "decimalValue": 0
      },
      {
        "testId": 14,
        "description": "R0 reset mid-count back to 0",
        "inputs": {"R0_1": "HIGH", "R0_2": "HIGH", "R9_1": "LOW", "R9_2": "LOW", "CKA": "LOW", "CKB": "LOW"},
        "expectedOutputs": {"QA": "LOW", "QB": "LOW", "QC": "LOW", "QD": "LOW"},
        "binaryValue": "0000",
        "decimalValue": 0
      }
    ]
  },
  
  "notes": [
    "For decade counter operation (0-9): Connect QA (pin 12) to CKB (pin 1) externally",
    "For divide-by-2: Use CKA input only, read QA output",
    "For divide-by-5: Use CKB input only, read QD output",
    "Reset to 0: Both R0(1) and R0(2) must be HIGH simultaneously",
    "Reset to 9: Both R9(1) and R9(2) must be HIGH simultaneously",
    "Outputs are BCD: 0000 through 1001 (0-9), then wraps to 0000"
  ]
}
