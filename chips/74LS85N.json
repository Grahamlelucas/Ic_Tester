{
  "chipId": "74LS85N",
  "name": "4-Bit Magnitude Comparator",
  "manufacturer": "Texas Instruments",
  "package": "16-pin DIP",
  "description": "4-bit magnitude comparator that compares two 4-bit binary words (A and B) and provides three outputs: A>B, A<B, A=B. Features cascading capability for multi-bit comparisons.",

  "pinout": {
    "vcc": 16,
    "gnd": 8,
    "inputs": [
      { "pin": 15, "name": "A3", "description": "A word bit 3 (MSB)" },
      { "pin": 13, "name": "A2", "description": "A word bit 2" },
      { "pin": 12, "name": "B1", "description": "B word bit 1" },
      { "pin": 11, "name": "A1", "description": "A word bit 1" },
      { "pin": 10, "name": "A0", "description": "A word bit 0 (LSB)" },
      { "pin": 9, "name": "B0", "description": "B word bit 0 (LSB)" },
      { "pin": 14, "name": "B2", "description": "B word bit 2" },
      { "pin": 1, "name": "B3", "description": "B word bit 3 (MSB)" },
      { "pin": 2, "name": "IAltB", "description": "Cascade input A<B" },
      { "pin": 3, "name": "IAeqB", "description": "Cascade input A=B" },
      { "pin": 4, "name": "IAgtB", "description": "Cascade input A>B" }
    ],
    "outputs": [
      { "pin": 5, "name": "AgtB", "description": "A greater than B output" },
      { "pin": 6, "name": "AeqB", "description": "A equal to B output" },
      { "pin": 7, "name": "AltB", "description": "A less than B output" }
    ],
    "noConnect": []
  },

  "arduinoMapping": {
    "comment": "Maps chip pins to Arduino Mega pins for testing",
    "power": {
      "16": "5V",
      "8": "GND"
    },
    "io": {
      "15": 22,
      "13": 23,
      "12": 24,
      "11": 25,
      "10": 26,
      "9": 27,
      "14": 28,
      "1": 29,
      "2": 30,
      "3": 31,
      "4": 32,
      "5": 33,
      "6": 34,
      "7": 35
    }
  },

  "testSequence": {
    "description": "Test sequence for 74LS85N 4-bit magnitude comparator",
    "tests": [
      {
        "testId": 1,
        "description": "Equal: A=0000, B=0000, cascade A=B HIGH",
        "inputs": {
          "A3": "LOW", "A2": "LOW", "A1": "LOW", "A0": "LOW",
          "B3": "LOW", "B2": "LOW", "B1": "LOW", "B0": "LOW",
          "IAgtB": "LOW", "IAltB": "LOW", "IAeqB": "HIGH"
        },
        "expectedOutputs": {
          "AgtB": "LOW", "AltB": "LOW", "AeqB": "HIGH"
        }
      },
      {
        "testId": 2,
        "description": "A > B: A=1000 (8) vs B=0000 (0)",
        "inputs": {
          "A3": "HIGH", "A2": "LOW", "A1": "LOW", "A0": "LOW",
          "B3": "LOW", "B2": "LOW", "B1": "LOW", "B0": "LOW",
          "IAgtB": "LOW", "IAltB": "LOW", "IAeqB": "HIGH"
        },
        "expectedOutputs": {
          "AgtB": "HIGH", "AltB": "LOW", "AeqB": "LOW"
        }
      },
      {
        "testId": 3,
        "description": "A < B: A=0000 (0) vs B=1000 (8)",
        "inputs": {
          "A3": "LOW", "A2": "LOW", "A1": "LOW", "A0": "LOW",
          "B3": "HIGH", "B2": "LOW", "B1": "LOW", "B0": "LOW",
          "IAgtB": "LOW", "IAltB": "LOW", "IAeqB": "HIGH"
        },
        "expectedOutputs": {
          "AgtB": "LOW", "AltB": "HIGH", "AeqB": "LOW"
        }
      },
      {
        "testId": 4,
        "description": "A > B: A=0101 (5) vs B=0011 (3)",
        "inputs": {
          "A3": "LOW", "A2": "HIGH", "A1": "LOW", "A0": "HIGH",
          "B3": "LOW", "B2": "LOW", "B1": "HIGH", "B0": "HIGH",
          "IAgtB": "LOW", "IAltB": "LOW", "IAeqB": "HIGH"
        },
        "expectedOutputs": {
          "AgtB": "HIGH", "AltB": "LOW", "AeqB": "LOW"
        }
      },
      {
        "testId": 5,
        "description": "A < B: A=0011 (3) vs B=0101 (5)",
        "inputs": {
          "A3": "LOW", "A2": "LOW", "A1": "HIGH", "A0": "HIGH",
          "B3": "LOW", "B2": "HIGH", "B1": "LOW", "B0": "HIGH",
          "IAgtB": "LOW", "IAltB": "LOW", "IAeqB": "HIGH"
        },
        "expectedOutputs": {
          "AgtB": "LOW", "AltB": "HIGH", "AeqB": "LOW"
        }
      },
      {
        "testId": 6,
        "description": "Equal: A=1111 (15) vs B=1111 (15)",
        "inputs": {
          "A3": "HIGH", "A2": "HIGH", "A1": "HIGH", "A0": "HIGH",
          "B3": "HIGH", "B2": "HIGH", "B1": "HIGH", "B0": "HIGH",
          "IAgtB": "LOW", "IAltB": "LOW", "IAeqB": "HIGH"
        },
        "expectedOutputs": {
          "AgtB": "LOW", "AltB": "LOW", "AeqB": "HIGH"
        }
      },
      {
        "testId": 7,
        "description": "Cascade: equal words, cascade A>B active",
        "inputs": {
          "A3": "LOW", "A2": "LOW", "A1": "LOW", "A0": "LOW",
          "B3": "LOW", "B2": "LOW", "B1": "LOW", "B0": "LOW",
          "IAgtB": "HIGH", "IAltB": "LOW", "IAeqB": "LOW"
        },
        "expectedOutputs": {
          "AgtB": "HIGH", "AltB": "LOW", "AeqB": "LOW"
        }
      },
      {
        "testId": 8,
        "description": "Cascade: equal words, cascade A<B active",
        "inputs": {
          "A3": "LOW", "A2": "LOW", "A1": "LOW", "A0": "LOW",
          "B3": "LOW", "B2": "LOW", "B1": "LOW", "B0": "LOW",
          "IAgtB": "LOW", "IAltB": "HIGH", "IAeqB": "LOW"
        },
        "expectedOutputs": {
          "AgtB": "LOW", "AltB": "HIGH", "AeqB": "LOW"
        }
      }
    ]
  },

  "notes": [
    "The 74LS85N is a 4-bit magnitude comparator",
    "Pin 3 (IA=B) should be tied HIGH for the least-significant comparator in a cascade chain",
    "Comparison starts from MSB (bit 3) down to LSB (bit 0)",
    "When all bits are equal, cascade inputs determine the output",
    "Propagation delay is typically 24ns"
  ]
}
